# Test Environment Variables for Multilingual Mandi Backend
# These are mock credentials for testing purposes only

# AWS Configuration (Mock credentials for testing)
AWS_ACCESS_KEY_ID=test_access_key_id
AWS_SECRET_ACCESS_KEY=test_secret_access_key
AWS_REGION=us-east-1

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1

# Application Configuration
NODE_ENV=test
PORT=5000

# Translation Service Configuration
TRANSLATION_CACHE_TTL=3600
TRANSLATION_MAX_RETRIES=3

# RAG Pipeline Configuration
RAG_MAX_DOCUMENTS=5
RAG_SIMILARITY_THRESHOLD=0.2
RAG_CONTEXT_WINDOW_SIZE=2000

# Vector Embedding Configuration
EMBEDDING_CACHE_TTL=7200
EMBEDDING_DIMENSION=384

# Price Service Configuration
PRICE_CACHE_TTL=1800
AGMARKNET_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070

# CSV Data Configuration
CSV_DATA_PATH=data/mandi_prices.csv
CSV_BACKUP_PATH=data/backup/

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000