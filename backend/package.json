{
  "name": "multilingual-mandi-backend",
  "version": "1.0.0",
  "description": "Backend service for Multilingual Mandi application",
  "main": "src/server/app.js",
  "scripts": {
    "dev": "nodemon src/server/app.js",
    "start": "node src/server/app.js",
    "build": "echo 'Backend build complete'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.478.0",
    "@aws-sdk/credential-providers": "^3.478.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "redis": "^4.6.10",
    "csv-parser": "^3.0.0",
    "papaparse": "^5.4.1",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "ml-matrix": "^6.10.7",
    "natural": "^6.12.0",
    "stopword": "^2.0.8"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "fast-check": "^3.15.0",
    "@types/jest": "^29.5.8"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server/app.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}